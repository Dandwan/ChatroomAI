{
  "name": "actichat",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "scripts": {
    "skill:sync:union-search": "node scripts/sync-union-search-skill.mjs",
    "dev": "npm run skill:sync:union-search && vite",
    "build": "npm run skill:sync:union-search && tsc -b && vite build --configLoader native",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:api": "node scripts/api-smoke-test.mjs",
    "runtime:package:node": "node scripts/package-node-runtime.mjs",
    "runtime:package:python": "node scripts/package-python-runtime.mjs",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && node scripts/cap-sync-android.mjs",
    "android:gradle": "node scripts/run-android-gradle.mjs",
    "android:build:debug": "npm run android:sync && npm run android:gradle -- assembleDebug",
    "android:build:release": "npm run android:sync && npm run android:gradle -- assembleRelease",
    "android:build": "npm run android:build:release"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
